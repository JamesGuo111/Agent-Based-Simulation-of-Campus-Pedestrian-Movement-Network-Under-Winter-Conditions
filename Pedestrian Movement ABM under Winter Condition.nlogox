<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[; Term Project
; Zijing Guo
; January 31, 2026

__includes ["pqueue.nls"]

breed [pedestrians pedestrian]
breed [nodes node]
breed [plows plow]

pedestrians-own [
  current-node                   ; store the current node pedestrians are on
  prev-node                      ; store the previous node pedestrians were on, uesd for not going back when randomly selecting next
  final-destination              ; the final building node pedestrians choose to go
  temp-destination               ; the temporary road/building node pedestrians are heading to
  route                          ; a list storing the shortest path from starting point to final destination
  route-index                    ; the index keep track of which part of the shortest path the pedestrian has reached
  need-reroute-on                ; stores the starting node to be rerouted from, this happens when the snow on the original road in the shortest path caused the pedestrian to select another road
                                 ; this variable is created mainly because of user context issue, see explanation in the move-pedestrian procedure.
  walking-time                   ; this variable records the length of time the pedestrian has been on the road yet still not reaching its destination.
]

nodes-own [
  node-type                       ; there are two types of node: building and road
  building-type                   ; for building node, what's the type of the building (Academic, Dining, Residential, Other). For road node, this would be "None"
  acc_dist                        ; this variable is used to store the accumulated distance for the Dijkstra's Algorithm when finding the shortest path for a pedestrian.
  parent                          ; stores the parent that adds it into the priority queue, used for the reconstructing path process for the searching algorithm
  pq-pos                          ; position index in the priority queue
  node-id                         ; for the file writing part to store the node-link graph already created, which needs a unique id for each node.
]

links-own [
  snow?                           ; boolean var to determine whether there's snow on the road
  walkability                     ; number of times pedestrians have walked on the road. When there's snow, higher walkability means more people have walked on the road to make it easier to walk.
  len                             ; = link-length for the searching algorithm
]

plows-own [
  current-node                    ; current position of the plow
  temp-destination                ; to store the next destination
]

globals [
  click-radius                    ; radius range for mouse to detect a node
  default-size                    ; default size of node when not pointed
  default-color-building          ; default color of building node, set to be orange (more noticeable)
  default-color-road              ; default color of road node, set to be black
  high-size                       ; when highlighted with mouse pointing on the point, change the size so that user knows
  high-color                      ; change to this color when mouse pointing
  ; building-type-to-make          ---- interface variable based on the chooser, used when creating a building node, assign the building type
  p-origin-academic               ; probability for academic building to generate pedestrians
  p-origin-dining                 ; probability for dining building to generate pedestrians
  p-origin-residential            ; probability for residential building to generate pedestrians
  p-origin-other                  ; probability for other building to generate pedestrians
  p-dest-academic                 ; probability for academic building to be set as final destination by pedestrians
  p-dest-dining                   ; probability for dining building to be set as final destination by pedestrians
  p-dest-residential              ; probability for residential building to be set as final destination by pedestrians
  p-dest-other                    ; probability for other building to be set as final destination by pedestrians
  average-walking-time            ; store the total walking time of all pedestrians divided by number of pedestrian
  ; num-ped                        ---- interface var: number of pedestrian, default 100
  ; speed-ped                      ---- interface var: moving speed of pedestrian, default 10
  ; reroute-p-when-snow            ---- interface var: probability to switch to a more walkable road when there's snow on the current one, default 0.3
  ; faster-threshold               ---- interface var: the threshold of walkability after which pedestrian can move faster if they choose to walk on such road. default 200
  ; speed-snow                     ---- interface var: the pedestrian speed when walking on snowy road, default 5
  ; speed-walkable-snow            ---- interface var: the pedestrian speed when walking on snowy road with walkability higher than the threshold, default 7
  ; num-plow                       ---- interface var: the number of plows on campus
  ; speed-plow                     ---- interface var: the speed of the plows
  ; snowed?                        ---- interface var: switch variable to set whether in snowed setting
  ; plow-strategy                  ---- interface var: the plow movement strategy, in string
  
  next-node-id                    ; for file writing function, store the next node id so that when previous nodes-links graph are loaded, user can still create new node/path following the id.
]

to setup
  clear-all
  import-drawing "campus_map.png"
  load-graph "complete-graph"
  set next-node-id 0
  set click-radius 10
  set high-size 20
  set default-size 10
  set default-color-road black
  set default-color-building orange
  set high-color red
  set p-origin-academic 0.3
  set p-origin-dining 0.3
  set p-origin-residential 0.3
  set p-origin-other 0.1
  set p-dest-academic 0.3
  set p-dest-dining 0.3
  set p-dest-residential 0.3
  set p-dest-other 0.1
  load-graph "complete-graph"
  reset-ticks
end

; this procedure would be more frequently used to set up new model because it does not clear-all, which is important because
; clear-all will remove the node-links graph and the user has to import again.
to reset-simulation
  ask pedestrians [die]
  ask plows [die]
  reset-ticks
  clear-plot
  ; based on users choices, set up different form of simulation
  ifelse snowed? [
    ask links [set snow? true set walkability 0 set color blue]
  ][
    ask links [set snow? false set walkability 0 set color yellow]
  ]
end

to go
  generate-pedestrians
  move-pedestrians
  move-plow
  if ticks = 2000 [if snow-plow? [generate-plow]] ; after 2000 ticks, generate plow. This is to make sure that original pattern is formed, then add plow to see how the patterns can be altered.
  ask pedestrians [set walking-time walking-time + 1]
  if show-walkability? [
    ask pedestrians [set hidden? true]
    update-link-visual
  ]
  set average-walking-time sum [walking-time] of pedestrians / num-ped
  tick
end


; ------------------------------------------ Basic Setup Tools ---------------------------------------

; this code is partially based on the "middtraffic" file delivered
; make nodes interactive with users through mouse movement
; Observer Context
to highlight
  ask nodes [
    ifelse distancexy mouse-xcor mouse-ycor <= click-radius [
      set size high-size
      set color high-color
    ][
      set size default-size
      ifelse node-type = "building" [
        set color default-color-building
      ][
        set color default-color-road]
    ]
  ]
end

; Observer Context
; implement the interactive features while making graph and report the position of mouse pointing.
to-report get-mouse-click
  while [not mouse-down?][highlight]
  while [mouse-down?][highlight]
  report (list mouse-xcor mouse-ycor)
end

; Observer Context
; report the node within the clicked position
to-report get-node
  let to-return nobody
  while [to-return = nobody] [
    let loc get-mouse-click
    ; loc is a list [x y]
    let x first loc
    let y last loc
    if any? nodes with [distancexy x y < click-radius][
      set to-return min-one-of nodes [distancexy x y]
    ]
  ]
  report to-return
end

; Observer Context
; draw a building node on the graph with selected building type
to make-building-node
  let loc get-mouse-click
  let x first loc
  let y last loc
  if not any? nodes with [distancexy x y < click-radius][ ; if a node already exists in the range, no new node will be created
    create-nodes 1[
      setxy x y
      set shape "circle"
      set color default-color-building
      set size default-size
      set node-type "building"
      set building-type building-type-to-make ; determined by the chooser in the interface
      set node-id next-node-id ; always keep track of this whenever a new node is created.
      set next-node-id next-node-id + 1
    ]
  ]
  ; restore all nodes to their normal states
  ; in some cases nodes may be kpet in highlighted form, which is not desired.
  ask nodes [
    set size default-size
    ifelse node-type = "building" [
      set color default-color-building
    ][set color default-color-road]
  ]  
end

; Observer Context
; draw a road node on the graph
to make-road-node
  let loc get-mouse-click
  let x first loc
  let y last loc 
  if not any? nodes with [distancexy x y < click-radius][ ; if a node already exists, won't create a new one
    create-nodes 1[
      setxy x y
      set shape "circle"
      set color default-color-road
      set size default-size
      set node-type "road"
      set building-type "None"
      set node-id next-node-id
      set next-node-id next-node-id + 1
    ]
  ]
  ; restore the nodes to their normal states
  ask nodes [
    set size default-size
    ifelse node-type = "building" [
      set color default-color-building
    ][set color default-color-road]
  ]  
end

; Observer Context
; Select two nodes and build an undirected link representing path between them
to make-path
  if count nodes > 1 [ ; only when there are more than 1 node can a path be created
    let node1 get-node
    let node2 get-node
    if node1 != node2 [
      ask node1 [
        create-link-with node2 [set thickness 5 
          set color yellow 
          set len link-length
          set snow? false
          set walkability 0
        ]
      ]
    ]
  ]
  ; restore all nodes to their normal states
  ask nodes [
    set size default-size
    ifelse node-type = "building" [
      set color default-color-building
    ][set color default-color-road]
  ] 
end

; Observer Context
; Select two nodes and delete the path between them. This is for the convenience of user when creating path, in case user makes mistakes.
to delete-path
  if count links != 0 [ ; only when there is at least one path can the method be called.
    let node1 get-node
    let node2 get-node
    if node1 != node2 [
      ask node1 [
        let path link-with node2
        if path != nobody [ask path [die]]
      ]
    ]
  ]
  ; restore all nodes to their normal states
  ask nodes [
    set size default-size
    ifelse node-type = "building" [
      set color default-color-building
    ][set color default-color-road]
  ] 
end

; Observer Context
; Delete the selected node for the convenience of user in case the wrongly created a node.
to delete-node
  if count nodes != 0 [ ; only when there is node can the method be used.
    let to-delete get-node
    ask to-delete [die]
  ]
  ; restore all nodes to their normal states
  ask nodes [
    set size default-size
    ifelse node-type = "building" [
      set color default-color-building
    ][set color default-color-road]
  ] 
end

; ------------------------------------- Graph Storage -----------------------------------
; Observer Context
; This procedure stores the node-link graph drawn by users to an external text file, 
; so that later when other users use this model, they can directly load the graph through load-graph.
to save-graph
  let f user-new-file
  if f = false [stop] ; if the user presses cancels and does not pick any file, then stop the procedure.
  
  file-close-all
  file-open f
  
  ;open the file to start file writing
  ; keep track of the globals next-node-id, so that after loading the graph, the user can keep creating new nodes following the node id.
  file-print (word "NEXT " next-node-id)
  
  ; start to store node
  file-print "NODES"
  
  ; get all nodes as a list, sorted based on their id.
  let ns sort-by [[a b] -> [node-id] of a < [node-id] of b] nodes
  ; write 1 line per node, each line is a list like: [0 415 1392 "building" "Other"]
  foreach ns [ n ->
    file-show (list [node-id] of n [xcor] of n [ycor] of n [node-type] of n [building-type] of n)
  ] ; note: here use file-show because it will write literal value, like "building" instead of building. Other method like file-print does not do so.
  
  ; start to store links
  file-print "LINKS"
  let ls sort links
  ; same as above
  foreach ls [ lk ->
    file-show (list [node-id] of [end1] of lk
                    [node-id] of [end2] of lk
                    [snow?] of lk
                    [walkability] of lk
                    [len] of lk)
  ]
  file-close
end

; Observer Context
; This procedures load a previously saved node-link graph from a text file and rebuild it in the NetLogo world.
to load-graph [file]
  let f file
  ; if f = false [stop]
  
  ; Clear existings
  ask pedestrians [die]
  ask links [die]
  ask nodes [die]
  
  import-drawing "campus_map.png"
  file-close-all
  file-open f
  
  ; local var mode is used to determine how to read a specific line based on what it's trying to build.
  let mode "none" 
  
  while [not file-at-end?] [ ; read through file
    let line file-read-line
    if length line >= 10 and substring line 0 10 = "observer: " [
      set line substring line 10 (length line)
    ]
    
    if line = "" [ ]  ; do nothing with empty line

    if line = "NODES" [set mode "nodes"] ; when reach the header, set mode to the specific type.
    if line = "LINKS" [set mode "links"]

    ; this is for the continuation of next-node-id so that later the user can create new nodes
    if length line >= 4 and substring line 0 4 = "NEXT" [
      set next-node-id read-from-string substring line 5 (length line)
    ]
    

    ; start reading node
    ; With file-show, each node line is already a NetLogo-readable list, e.g.: [0 415 1392 "building" "Other"]
    if mode = "nodes" and line != "NODES" and line != "LINKS"
    and not ((length line >= 4) and (substring line 0 4 = "NEXT")) [
      
      let row read-from-string line   ; row is a list: [id x y node-type building-type]
      create-nodes 1 [ ; rebuild the node based on what's stored 
        ; follows the structure of row to get corresponding info for each variable
        set node-id (item 0 row)
        setxy (item 1 row) (item 2 row)
        set node-type (item 3 row)
        set building-type (item 4 row)
        
        set shape "circle"
        set size default-size
        ifelse node-type = "building"
          [set color default-color-building]
        [set color default-color-road]
        
      ]
    ]
    
    ; start reading links
    ; Link line is also a NetLogo-readable list, e.g.:[0 6 0 0 79.63]
    if mode = "links" and line != "LINKS" [
      let row read-from-string line   ; row: [id1 id2 snow? walkability len]
      let id1 (item 0 row)
      let id2 (item 1 row)
      let n1 one-of nodes with [node-id = id1]
      let n2 one-of nodes with [node-id = id2]
      ask n1 [
        create-link-with n2 [
          set snow? (item 2 row)
          set walkability (item 3 row)
          set len (item 4 row)
          set color yellow
          set thickness 5
        ]
      ]
    ]
  ]
  
  file-close
end

; --------------------------------------- Pedestrian Related -----------------------------------------
; Observer Conetext
; Generate pedestrians from a random building based on the assigned probability for four types of building.
; After generated, pedestrians would randomly pick a final destination based on the assigned probability and find the shortest path between where they are born and their destination.
to generate-pedestrians
  while [count pedestrians < num-ped] [ ; maintain the total number of pedestrians to a fixed level
    let origin-type choose-origin-type ; choose building based on the assigned probability
    ; The reason to create a local variable that tracks the created pedestrian is because the shortest-path procedure is in observer context. It cannot be called in create-pedestrian.
    ; By creating a local variable in observer context, the shortest-path can be called to find path for the specific pedestrian then get back to pedestrian context.
    ; It should be noticed that the shortest-path must be in observer context because it calls the external pqueue.nls. There's no space for choices between context for this procedure.
    let ped nobody
    create-pedestrians 1 [
      set size 20
      set color black
      let origin one-of nodes with [building-type = origin-type]
      move-to origin
      set current-node origin
      set prev-node origin
      set final-destination pick-final-destination origin
      set need-reroute-on nobody
      ; In case an agent cannot find a destination, this should never happen.
      if final-destination = nobody [die]
      set ped self
    ]
    ; step out of the pedestrian context to call shortest path
    let r shortest-path [current-node] of ped [final-destination] of ped
    ; then step back to assign the path
    ask ped [
      set route r
      set route-index 1
      set temp-destination item route-index route
    ]
  ]
end

; Observer context
; The core pedestrians moving logic implementation
to move-pedestrians
  ask pedestrians [
    let lk [link-with [temp-destination] of myself] of current-node ; find the current road it's on
    let step-speed speed-ped ; the speed varies under different road condition, in normal case without snow, this is just the speed-ped.
    if [snow?] of lk [
      set step-speed speed-snow ; if there's snow, set speed to speed-snow
      if [walkability] of lk > faster-threshold [set step-speed speed-walkable-snow] ; if the walkability is larger the threshold to make a road easier and faster to walk, adjust the speed.
    ]
    face temp-destination
    let d distance temp-destination
    ifelse d <= step-speed [ ; getting close to the end of the path
      move-to temp-destination ; directly move to the destination
      ask lk [set walkability walkability + 1] ; every time a road is walked, its walkability + 1
      set prev-node current-node ; keep track of its previous node, so that the future choice for pedestrians won't include previous node only they have no other choice.
      set current-node temp-destination
      if current-node = final-destination [die] ; if they arrive to their final destination, they will die.
      ; normal condition without snow
      set route-index route-index + 1 ; keep track of where pedestrians are at in their shortest path list.
      set temp-destination item route-index route ; follow the node included in the shortest path
      if temp-destination = nobody [die] ; a safety logic, should not happen
      ; After new temp-destination is gotten from their original shortest path list, the pedestrians need to decide whether they want to change their choice of road if they meet snowy road.
      let next-road ([link-with [temp-destination] of myself] of current-node)
      if [snow?] of next-road [
        if random-float 1 < reroute-p-when-snow [ ; under such probability will pedestrian change their route choice
          let nbrs ([link-neighbors] of current-node) with [self != [prev-node] of myself]
          ; The overall logic here is that if a pedestrian wants to change their route choice due to the snow, they will choose the one that is most walkable.
          ; If there's more than one most walkable route, choose the one closer their final destination.
          if any? nbrs [
            ; first, find a neighbor with highest walkability
            let best-nbr max-one-of nbrs [[walkability] of (link-with [current-node] of myself)]
            ; then, use best-walk to store this highest walkability
            let best-walk [walkability] of ([link-with best-nbr] of current-node)
            ; find all neighbors with the highest-walkability
            let bests nbrs with [[walkability] of (link-with [current-node] of myself) = best-walk]
            ; choose the one that is closest to the final destination
            let best-candidate min-one-of bests [distance [final-destination] of myself]
            
            if [walkability] of next-road != best-walk [; if equal, then no need to reroute because the shortest path is already with the highest walkability.
              set need-reroute-on best-candidate ; if one decides to reroute and there's more walkable route than the original one, set need-reroute-on to be the best-candidate
            ]
          ]
        ]
      ]
    ][
      fd step-speed ; if the pedestrian has gotten close to its temp-destination, just keep moving.
    ]
  ]
  ; It should be specified here about why the variable need-reroute-on is necessary: the fundamental reason is the same as what happens in generate-pedestrian. The shortest-path procedure is and 
  ; must be in observer context, so we must step out the pedestrian context of ask pedestrians to actually call shortest-path. However, if we step out of ask pedestrians, we will lose track of which
  ; pedestrian we were dealing with, and creating local variables like the way in generate-pedestrian won't work because ask pedestrians call multiple of them rather a single of them. As a result, I
  ; had to create a pedestrian variable to keep track of which pedestrian need reroute and where they need reroute. If need-reroute-on is nobody, it means the pedestrian does not need to reroute. 
  ; Otherwise, the need-reroute-on will store on which node they want to reroute, so that we can call the procedure finding shortest path between their final destination and the node.
  while [any? pedestrians with [need-reroute-on != nobody]] [
    let ped one-of pedestrians with [need-reroute-on != nobody]
    let new-route shortest-path ([need-reroute-on] of ped) ([final-destination] of ped) ; call shortest-path to find new route
    ask ped [ ; step back to pedestrian context to assign the new route
      set route fput current-node new-route
      set route-index 1
      set temp-destination item route-index route
      set need-reroute-on nobody
    ]
  ]
end

; ---------------------------- Tools for initiating pedestrians and planning movement -------------------

; for generate-pedestrians, choose what types of building as origin
to-report choose-origin-type
  report weighted-choice
    ["Academic" "Dining" "Residential" "Other"]
    (list p-origin-academic p-origin-dining p-origin-residential p-origin-other)
end

; for generate-pedestrians, choose what types of building as final destination
to-report choose-dest-type
  report weighted-choice
    ["Academic" "Dining" "Residential" "Other"]
    (list p-dest-academic p-dest-dining p-dest-residential p-dest-other)
end

; a helper to make stochastic choice based on weighted probability
to-report weighted-choice [labels weights]
  let total sum weights
  let r random-float total
  let acc 0
  ; use anonymous reporter
  (foreach labels weights [ [lab w] ->
    set acc acc + w
    if r <= acc [ report lab ]
  ])
end

; the reporter to pick a final destination after being born on a building node
to-report pick-final-destination [origin-node]
  let dest-type choose-dest-type
  let candidates nodes with [
    node-type = "building" and ; make sure to choose a building node rather than road node
    building-type = dest-type and
    self != origin-node  ; make sure to not select where they are born
  ]
  if not any? candidates [ ; safety case, should not happen with the complete-graph provided
    set candidates nodes with [node-type = "building" and self != origin-node]
  ]
  if not any? candidates [ report nobody ]
  report one-of candidates
end

; Observer Context
; The implementation of Djikstra's Algorithm for finding the shortest path between two nodes with weighted path, which is the distance of path in this case.
to-report shortest-path [start dest]
  ask nodes [
    set acc_dist 1.0E18 ; set to infinity
    set parent nobody ; no predecessor yet
    set pq-pos -1 ; not in priority queue yet
  ]
  ask start [set acc_dist 0] ; the distance to starting node is 0.
  ; create a new priority queue
  let pq-ct  [ [?1 ?2] -> [acc_dist] of ?1 < [acc_dist] of ?2 ]
  let pq-upt [ [?1 ?2] -> ask ?1 [ set pq-pos ?2 ] ]
  let q pq-new pq-ct pq-upt
  ; insert first node into pq
  pq-insert q start
  ; main loop, keep inserting and taking out from pq
  while [not pq-empty? q][
    let cur pq-delete-front q ; each time take out the topest node in pq
    ask cur [set pq-pos -1] ; remove it from the priority queue
    if cur = dest [ ; found the final destination
      report reconstruct-path start dest ; then start to collect nodes of the shortest path into a list
    ]
    ask cur [
      ask link-neighbors [
        let w [len] of link-with cur ; the weight of path is link length, representing the distance between node
        let alternative ([acc_dist] of cur) + w
        ; if a shorter path is found, update the node in the prioerity queue
        if alternative < acc_dist [
          set acc_dist alternative
          set parent cur
          let pos pq-pos
          ifelse pos >= 0 [
            ask q [pq-bubble pos] ; update position in pq if already in it
          ][
            pq-insert q self ; otherwise put itself into the pq
          ]
        ]
      ]
    ]
  ]
  report [] ; safety case for unreachable destination, won't happen with the provided complete-graph
end

; the core function for the Dijkstra's Algorithm to find the list of nodes in shortest path
to-report reconstruct-path [start dest]
  let p (list dest)
  let cur dest ; starting from the end
  while [cur != start][ ; keep moving back until find the starting point.
    set cur [parent] of cur
    set p fput cur p
  ]
  report p
end
  
; ---------------------------------- Plow Related ------------------------------------------
; Observer Context
; create plow on a random node (including road node) if required
to generate-plow
  create-plows num-plow [
    set size 25
    set color red
    set shape "square"
    set current-node one-of nodes
    move-to current-node
    set temp-destination nobody
  ]
end

; Observer Context
; The implementation of the moving logic and strategies of snow plow.
to move-plow
  ask plows [
    ifelse temp-destination = nobody [ ; when the plow has arrived a node and wait to plan for the next path
      let nbrs [link-neighbors] of current-node
      if any? nbrs [
        let snowy nbrs with [[snow?] of (link-with [current-node] of myself)] ; always first find any snowy path to go
        ifelse any? snowy [ ; if there are multiple snowy roads, that's where the plow strategies come in.
          if plow-strategy = "clean-more-walked" [
            set temp-destination max-one-of snowy [[walkability] of (link-with [current-node] of myself)] ; choose the snowy condition with highest walkability
          ]
          if plow-strategy = "clean-less-walked" [
            set temp-destination min-one-of snowy [[walkability] of (link-with [current-node] of myself)] ; choose the snowy condition with lowest walkability
          ]
        ][
          set temp-destination one-of nbrs ; if no any snowy path, move to a random node.
        ]
    ]][
      face temp-destination
      let d distance temp-destination
      ifelse d <= speed-plow [
        let old current-node
        move-to temp-destination
        ask old [ ; when it completely passes a road, set snow? false representing it removes the snow on the path.
          let lk link-with [temp-destination] of myself
          ask lk [set snow? false set color yellow] 
        ]
        
        set current-node temp-destination
        set temp-destination nobody
      ] [
        fd speed-plow
      ]
    ]
  ]
end

; ------------------- Visualization ----------------------
; To visually represent which path is walked more on the graph. The more black a path is, the more walked it is.
to update-link-visual
  let maxW max [walkability] of links
  ask links [
    let ratio 0
    if maxW != 0 [
    set ratio walkability / maxW
    ]
    set color ((1 - ratio) * 9.9)
  ]
end]]></code>
