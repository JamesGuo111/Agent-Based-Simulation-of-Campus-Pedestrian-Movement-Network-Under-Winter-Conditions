  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="experiment" repetitions="10" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="5000">
      <setup>reset-simulation</setup>
      <go>go</go>
      <runMetricsCondition>ticks mod 1000 = 0</runMetricsCondition>
      <metrics>
        <metric>(sum [walking-time] of pedestrians) / num-ped</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="num-ped">
          <value value="100"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="num-plow">
          <value value="1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="building-type-to-make">
          <value value="&quot;Other&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="show-walkability?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="snow-plow?">
          <value value="false"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-snow">
          <value value="1"></value>
          <value value="3"></value>
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-plow">
          <value value="15"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="snowed?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-ped">
          <value value="10"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-walkable-snow">
          <value value="5"></value>
          <value value="7"></value>
          <value value="9"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="reroute-p-when-snow">
          <value value="0.3"></value>
          <value value="0.5"></value>
          <value value="0.7"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="faster-threshold">
          <value value="200"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
    <experiment name="plow-stategy-effectiveness" repetitions="5" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="10000">
      <setup>setup
reset-simulation</setup>
      <go>go</go>
      <runMetricsCondition>ticks mod 1000 = 0</runMetricsCondition>
      <metrics>
        <metric>average-walking-time</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="num-ped">
          <value value="100"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="num-plow">
          <value value="1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="building-type-to-make">
          <value value="&quot;Other&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="show-walkability?">
          <value value="false"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="snow-plow?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-snow">
          <value value="1"></value>
          <value value="5"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-plow">
          <value value="15"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="snowed?">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-ped">
          <value value="10"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="plow-strategy">
          <value value="&quot;clean-less-walked&quot;"></value>
          <value value="&quot;clean-more-walked&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="speed-walkable-snow">
          <value value="5"></value>
          <value value="10"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="reroute-p-when-snow">
          <value value="0.3"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="faster-threshold">
          <value value="10"></value>
          <value value="100"></value>
          <value value="500"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
